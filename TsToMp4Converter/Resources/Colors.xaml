<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Palette (from UI/UX Pro Max: Modern Dark Cinema) -->
    <Color x:Key="Color.Background">#0F172A</Color>
    <Color x:Key="Color.Surface">#1E293B</Color>
    <Color x:Key="Color.SurfaceAlt">#273548</Color>
    <Color x:Key="Color.Card">#253246</Color>
    <Color x:Key="Color.CardHover">#2F3E55</Color>
    <Color x:Key="Color.Foreground">#F8FAFC</Color>
    <Color x:Key="Color.Muted">#94A3B8</Color>
    <Color x:Key="Color.Accent">#22C55E</Color>
    <Color x:Key="Color.AccentDim">#16A34A</Color>
    <Color x:Key="Color.AccentGlow">#1A4A2E</Color>
    <Color x:Key="Color.Destructive">#EF4444</Color>
    <Color x:Key="Color.DestructiveDim">#B91C1C</Color>
    <Color x:Key="Color.Warning">#F59E0B</Color>
    <Color x:Key="Color.Border">#334155</Color>
    <Color x:Key="Color.BorderLight">#475569</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}"/>
    <SolidColorBrush x:Key="Brush.Card" Color="{StaticResource Color.Card}"/>
    <SolidColorBrush x:Key="Brush.CardHover" Color="{StaticResource Color.CardHover}"/>
    <SolidColorBrush x:Key="Brush.Foreground" Color="{StaticResource Color.Foreground}"/>
    <SolidColorBrush x:Key="Brush.Muted" Color="{StaticResource Color.Muted}"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.AccentDim" Color="{StaticResource Color.AccentDim}"/>
    <SolidColorBrush x:Key="Brush.AccentGlow" Color="{StaticResource Color.AccentGlow}"/>
    <SolidColorBrush x:Key="Brush.Destructive" Color="{StaticResource Color.Destructive}"/>
    <SolidColorBrush x:Key="Brush.DestructiveDim" Color="{StaticResource Color.DestructiveDim}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>
    <SolidColorBrush x:Key="Brush.BorderLight" Color="{StaticResource Color.BorderLight}"/>

    <!-- Status Colors -->
    <SolidColorBrush x:Key="Brush.StatusQueued" Color="#64748B"/>
    <SolidColorBrush x:Key="Brush.StatusConverting" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.StatusCompleted" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.StatusFailed" Color="{StaticResource Color.Destructive}"/>
    <SolidColorBrush x:Key="Brush.StatusCancelled" Color="{StaticResource Color.Warning}"/>
</ResourceDictionary>
