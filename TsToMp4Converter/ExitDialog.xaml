<Window x:Class="TsToMp4Converter.ExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exit"
        Height="280" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource Brush.Background}"
            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
            CornerRadius="10" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⚠" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Exit" FontWeight="SemiBold" FontSize="16"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Padding="4" Click="CancelButton_Click"
                            Width="24" Height="24">
                        <TextBlock Text="✕" FontSize="12"
                                   Foreground="{StaticResource Brush.Muted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="32,0">
                <TextBlock Text="Don't forget to support the creator! ❤️"
                           FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           TextAlignment="Center"/>
                <TextBlock Margin="0,10,0,0" FontSize="12"
                           Foreground="{StaticResource Brush.Muted}"
                           HorizontalAlignment="Center">
                    <Hyperlink NavigateUri="https://ko-fi.com/gauravdubeypro"
                               RequestNavigate="KofiLink_RequestNavigate"
                               Foreground="{StaticResource Brush.Accent}"
                               FontSize="12">
                        ko-fi.com/gauravdubeypro
                    </Hyperlink>
                </TextBlock>
                <Button x:Name="KofiButton" Margin="0,10,0,0"
                        Style="{StaticResource GhostButton}"
                        Background="{StaticResource Brush.AccentGlow}"
                        BorderBrush="{StaticResource Brush.Accent}" BorderThickness="1"
                        Padding="20,6" Cursor="Hand"
                        HorizontalAlignment="Center"
                        Click="KofiButton_Click">
                    <TextBlock Foreground="{StaticResource Brush.Accent}"
                               FontWeight="SemiBold" FontSize="12">
                        ☕ Support on Ko-fi
                    </TextBlock>
                </Button>
            </StackPanel>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10" Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource SecondaryButton}"
                            Padding="20,6" Margin="0,0,10,0"
                            Click="CancelButton_Click"
                            IsCancel="True">
                        <TextBlock Text="Cancel" FontSize="12"/>
                    </Button>
                    <Button x:Name="ExitButton"
                            Style="{StaticResource DangerButton}"
                            Padding="20,6" Cursor="Hand"
                            Click="ExitButton_Click"
                            IsDefault="True">
                        <TextBlock Text="Yes, exit" FontWeight="SemiBold"
                                   Foreground="#FFFFFF" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>