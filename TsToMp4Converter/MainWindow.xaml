<Window x:Class="TsToMp4Converter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TsToMp4Converter.ViewModels"
        xmlns:models="clr-namespace:TsToMp4Converter.Models"
        Title="TS to MP4 Converter"
        Icon="pack://application:,,,/Resources/ts-to-mp4.ico"
        Height="680" Width="960"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        PreviewDragOver="Window_PreviewDragOver"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.Foreground}">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Status-to-color converter for list items -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Queued">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusQueued}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Converting">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusConverting}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Completed">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusCompleted}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Failed">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusFailed}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusCancelled}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FileProgressBar" TargetType="ProgressBar">
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="Background" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Failed">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusFailed}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Completed">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusCompleted}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Queued">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusQueued}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Converting">
                    <Setter Property="Foreground" Value="{StaticResource Brush.StatusConverting}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1"
                Padding="28,16,28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="TS to MP4 Converter" Style="{StaticResource Heading}"/>
                    <TextBlock Text="Remux .ts video files to .mp4 — zero quality loss, same resolution"
                               Style="{StaticResource Subheading}" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource Brush.AccentGlow}"
                        BorderBrush="{StaticResource Brush.Accent}" BorderThickness="1"
                        CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                    <TextBlock Text="v1.0" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Accent}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ TOOLBAR ═══════ -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarCard}" Margin="24,16,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Add/Clear -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Command="{Binding AddFilesCommand}" Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontWeight="Bold" FontSize="15" Margin="0,0,6,0"/>
                            <TextBlock Text="Add Files"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearFilesCommand}" Style="{StaticResource GhostButton}" Margin="8,0,0,0">
                        Clear
                    </Button>
                    <Button x:Name="HelpButton" Style="{StaticResource GhostButton}" Margin="4,0,0,0"
                            Click="HelpButton_Click" ToolTip="How to use this software"
                            Width="28" Height="28">
                        <TextBlock Text="?" FontWeight="Bold" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Center: Output path -->
                <Border Grid.Column="1" Background="{StaticResource Brush.Background}"
                        BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        CornerRadius="6" Padding="4,2" Margin="20,0,0,0"
                        VerticalAlignment="Center" Height="32">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="📁" FontSize="14"
                                   VerticalAlignment="Center" Margin="8,0,6,0"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding OutputFolder, TargetNullValue='Same as input folder'}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Muted}"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="12"/>

                        <Button Grid.Column="2" Command="{Binding BrowseOutputCommand}"
                                Style="{StaticResource GhostButton}"
                                Padding="8,2" FontSize="11" Margin="4,0,0,0"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="0,0,1,0"
                                ToolTip="Choose output folder">
                            <TextBlock Text="Browse" Foreground="{StaticResource Brush.Accent}"
                                       FontSize="11" FontWeight="SemiBold"/>
                        </Button>

                        <Button Grid.Column="3" Command="{Binding OpenOutputFolderCommand}"
                                Style="{StaticResource GhostButton}"
                                Padding="8,2" FontSize="11"
                                ToolTip="Open output folder in Explorer">
                            <TextBlock Text="Open" Foreground="{StaticResource Brush.Muted}"
                                       FontSize="11"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Right: FFmpeg status -->
                <Border Grid.Column="2" MinWidth="140"
                        BorderThickness="1" CornerRadius="6" Padding="10,6"
                        Visibility="{Binding FfmpegMissing, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1A1A2E"/>
                            <Setter Property="BorderBrush" Value="#F59E0B"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDownloadingFfmpeg}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Brush.AccentGlow}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Foreground="#FBBF24" FontSize="12"
                                   Visibility="{Binding IsDownloadingFfmpeg, Converter={StaticResource BoolToVisInverse}}">
                            ffmpeg.exe missing
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource Brush.Accent}" FontSize="12"
                                   Visibility="{Binding IsDownloadingFfmpeg, Converter={StaticResource BoolToVis}}">
                            <Run Text="{Binding FfmpegDownloadStatus}"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding FfmpegDownloadProgress}" Maximum="100"
                                     Height="3" Margin="0,4,0,0"
                                     Visibility="{Binding IsDownloadingFfmpeg, Converter={StaticResource BoolToVis}}"/>
                        <Button Command="{Binding DownloadFfmpegCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="8,3" FontSize="11"
                                Margin="0,4,0,0"
                                Visibility="{Binding IsDownloadingFfmpeg, Converter={StaticResource BoolToVisInverse}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬇" Margin="0,0,4,0"/>
                                <TextBlock Text="Download ffmpeg"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ FILE LIST ═══════ -->
        <Border Grid.Row="2" Style="{StaticResource StatusCard}" Margin="24,12,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Empty state (visible only when no files) -->
                <Border Grid.Row="0" Grid.RowSpan="3"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="No files added" FontSize="28"
                                   Foreground="{StaticResource Brush.Muted}"
                                   HorizontalAlignment="Center" Opacity="0.5"/>
                        <TextBlock Text="Click 'Add Files' or drag &amp; drop .ts files here"
                                   Foreground="{StaticResource Brush.Muted}"
                                   FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center" Opacity="0.35"/>
                    </StackPanel>
                </Border>

                <!-- Column headers (visible when files exist) -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="3" Text="File" Style="{StaticResource Subheading}" FontSize="11"/>
                    <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource Subheading}" FontSize="11"/>
                    <TextBlock Grid.Column="5" Text="Progress" Style="{StaticResource Subheading}" FontSize="11"/>
                    <TextBlock Grid.Column="6" Text="Error" Style="{StaticResource Subheading}" FontSize="11"/>
                </Grid>

                <!-- File items (visible when files exist) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              BorderThickness="0" Padding="0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Files}">
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="FrameworkElement.Margin" Value="0,0,0,6"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Brush.BorderLight}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="0"
                                        Background="{StaticResource Brush.Card}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Brush.CardHover}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left accent strip (green) -->
                                        <Rectangle Grid.Column="0" Fill="{StaticResource Brush.Accent}"
                                                   Width="4" HorizontalAlignment="Stretch"
                                                   RadiusX="2" RadiusY="2">
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Fill" Value="{StaticResource Brush.Destructive}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Converting">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Queued">
                                                            <Setter Property="Opacity" Value="0.3"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>

                                        <!-- Remove button -->
                                        <Button Grid.Column="1"
                                                Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Padding="0"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                                Width="22" Height="22"
                                                ToolTip="Remove from list">
                                            <TextBlock Text="✕" FontSize="11"
                                                       Foreground="{StaticResource Brush.Muted}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Converting">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Opacity" Value="0.1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Status icon -->
                                        <TextBlock Grid.Column="2" Text="●" FontSize="8"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Style="{StaticResource StatusTextStyle}"/>

                                        <!-- File name -->
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="4,8">
                                            <TextBlock Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding InputPath}"
                                                       FontSize="13"/>
                                        </StackPanel>

                                        <!-- Status -->
                                        <TextBlock Grid.Column="4" Text="{Binding Status}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource StatusTextStyle}"/>

                                        <!-- Progress -->
                                        <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="0,8">
                                            <ProgressBar Value="{Binding Progress}"
                                                         Style="{StaticResource FileProgressBar}"/>
                                            <TextBlock Text="{Binding Progress, StringFormat='{}{0:F0}%'}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource Brush.Muted}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Error -->
                                        <TextBlock Grid.Column="6"
                                                   Text="{Binding ErrorMessage}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding ErrorMessage}"
                                                   Foreground="{StaticResource Brush.StatusFailed}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════ STATUS BAR ═══════ -->
        <Border Grid.Row="3" Style="{StaticResource ToolbarCard}"
                Margin="24,12,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource Brush.Muted}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <ProgressBar Value="{Binding OverallProgress}" Maximum="100"
                                 Height="5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Button Command="{Binding OpenOutputFolderCommand}"
                            Style="{StaticResource GhostButton}"
                            Padding="10,4" Margin="0,0,8,0"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                            ToolTip="Open output folder in Explorer">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Open Output" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Margin="0,0,12,0"/>

                    <TextBlock FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="{Binding CompletedFiles}"/>
                        <Run Text="done"/>
                        <Run Text="{Binding TotalFiles, StringFormat='/ {0} total'}"
                             Foreground="{StaticResource Brush.Muted}"/>
                    </TextBlock>

                    <Button Command="{Binding ConvertAllCommand}"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConverting}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FfmpegMissing}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity" Value="0.35"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TotalFiles}" Value="0">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity" Value="0.35"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock Text="Convert All"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelConversionCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConverting}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="IsEnabled" Value="True"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" FontSize="11" Margin="0,0,6,0"/>
                            <TextBlock Text="Cancel"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ FOOTER ═══════ -->
        <Border Grid.Row="4" Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0"
                Padding="24,6,24,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Made by -->
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource Brush.Muted}">
                    <Run Text="made by "/>
                    <Run Text="Gaurav Dubey" FontWeight="SemiBold"/>
                </TextBlock>

                <!-- Center: Version -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Version, StringFormat='v{0}'}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource Brush.Muted}"/>

                <!-- Right: Ko-fi link -->
                <Button Grid.Column="2" x:Name="KofiButton"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Padding="6,2" Click="KofiButton_Click"
                        ToolTip="https://ko-fi.com/gauravdubeypro">
                    <TextBlock FontSize="11" Foreground="{StaticResource Brush.Accent}"
                               TextDecorations="Underline">
                        <Run Text="☕ "/>
                        <Run Text="Support on Ko-fi"/>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
